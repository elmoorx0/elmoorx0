{
  "name": "@elmoorx/cli",
  "version": "3.0.0-alpha.3",
  "description": "CLI tool: init, dev, build, deploy, generate, doctor",
  "type": "module",
  "bin": {
    "elmoorx": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@elmoorx/runtime": "*",
    "@elmoorx/compiler": "*",
    "@elmoorx/ai-copilot": "*"
  },
  "license": "MIT",
  "author": "Elmoorx Framework",
  "homepage": "https://elmoorx.dev/packages/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/elmoorx0/elmoorx0",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/elmoorx0/elmoorx0/issues"
  },
  "keywords": [
    "elmoorx",
    "framework",
    "cli"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
