{
  "name": "@elmoorx/compiler",
  "version": "3.0.0-alpha.2",
  "description": "JSX-to-Elmoorx compiler with esbuild integration, SSR, HMR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@babel/plugin-transform-typescript": "^7.24.0"
  },
  "peerDependencies": {
    "@elmoorx/runtime": "*"
  },
  "license": "MIT",
  "author": "Elmoorx Framework",
  "homepage": "https://elmoorx.dev/packages/compiler",
  "repository": {
    "type": "git",
    "url": "https://github.com/elmoorx0/elmoorx0",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/elmoorx0/elmoorx0/issues"
  },
  "keywords": [
    "elmoorx",
    "framework",
    "compiler"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
