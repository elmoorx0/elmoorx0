{
  "name": "@elmoorx/i18n",
  "version": "3.0.0-alpha.3",
  "description": "Internationalization: locale switching, RTL support, pluralization, calendars",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reactive": {
      "types": "./dist/reactive.d.ts",
      "default": "./dist/reactive.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "default": "./dist/loader.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "default": "./dist/format.js"
    },
    "./plural": {
      "types": "./dist/plural.d.ts",
      "default": "./dist/plural.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@elmoorx/runtime": "*"
  },
  "keywords": [
    "elmoorx",
    "framework",
    "i18n"
  ],
  "license": "MIT",
  "author": "Elmoorx Framework",
  "homepage": "https://elmoorx.dev/packages/i18n",
  "repository": {
    "type": "git",
    "url": "https://github.com/elmoorx0/elmoorx0",
    "directory": "packages/i18n"
  },
  "bugs": {
    "url": "https://github.com/elmoorx0/elmoorx0/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "test": "npx tsx --test tests/*.test.mjs",
    "prepublishOnly": "npm run build"
  }
}
