{
  "name": "@elmoorx/server",
  "version": "3.0.0-alpha.2",
  "description": "Full-stack HTTP server with middleware, static files, API routes, WebSocket",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./ssg": {
      "types": "./dist/ssg.d.ts",
      "default": "./dist/ssg.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@elmoorx/runtime": "*"
  },
  "license": "MIT",
  "author": "Elmoorx Framework",
  "homepage": "https://elmoorx.dev/packages/server",
  "repository": {
    "type": "git",
    "url": "https://github.com/elmoorx0/elmoorx0",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/elmoorx0/elmoorx0/issues"
  },
  "keywords": [
    "elmoorx",
    "framework",
    "server"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
