{
  "name": "@elmoorx/ui",
  "version": "3.0.0-alpha.2",
  "description": "648-component UI library (forms, layout, nav, data, feedback, media, pro)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./extended": {
      "types": "./dist/extended.d.ts",
      "default": "./dist/extended.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "default": "./dist/advanced.js"
    },
    "./pro": {
      "types": "./dist/pro.d.ts",
      "default": "./dist/pro.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "default": "./dist/catalog/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@elmoorx/runtime": "*"
  },
  "license": "MIT",
  "author": "Elmoorx Framework",
  "homepage": "https://elmoorx.dev/packages/ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/elmoorx0/elmoorx0",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/elmoorx0/elmoorx0/issues"
  },
  "keywords": [
    "elmoorx",
    "framework",
    "ui"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
